# Copy this file to .env and fill in your values
# .env is gitignored — never committed

# ── LLM Provider (pick ONE) ───────────────────────────────────────────────
LLM_PROVIDER=groq          # free — get key at console.groq.com
# LLM_PROVIDER=gemini      # free — get key at aistudio.google.com
# LLM_PROVIDER=ollama      # local/free — install ollama.ai first
# LLM_PROVIDER=anthropic   # paid

# ── API Keys (set the one matching your LLM_PROVIDER) ────────────────────
GROQ_API_KEY=gsk_...       # free at console.groq.com
# GEMINI_API_KEY=AIza...   # free at aistudio.google.com
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_MODEL=llama3.2    # optional, default is llama3.2

# ── Brave Search (free — 2000 queries/month) ──────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...   # free at brave.com/search/api

# ── Email (only needed for live send, not --dry-run) ──────────────────────
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password