# Copy this file to n8n/.env and fill in your values.
# n8n/.env is gitignored.

# ── n8n admin credentials ─────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_me_strong_password

# ── API keys ──────────────────────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search (free tier — 2000 queries/month):
# https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=BSA...

# ── Email ─────────────────────────────────────────────────────────────────
EMAIL_RECIPIENT=your.name@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────
TIMEZONE=America/Los_Angeles    # or Asia/Kolkata
N8N_HOST=localhost               # set to your domain if deployed to cloud